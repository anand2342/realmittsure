APP_NAME="Mittlearn"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/
# -------------------------------
# Database Configuration
# -------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mittlearn_db   ## Your Database name
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------
# Cache and Session
# -------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -------------------------------
# Mail Configuration
# -------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=yourpassword
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=youremail@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------
# Logging
# -------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------
# Razorpay Payment Gateway
# -------------------------------
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# -------------------------------
# Excel / CSV Exports
# -------------------------------
EXCEL_EXPORT_MEMORY_LIMIT=512M

# -------------------------------
# Captcha Configuration (mews/captcha)
# -------------------------------
CAPTCHA_LENGTH=5
CAPTCHA_WIDTH=150
CAPTCHA_HEIGHT=50
CAPTCHA_QUALITY=90

# -------------------------------
# Activity Log Configuration (spatie/laravel-activitylog)
# -------------------------------
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_LOG_ONLY_DIRTY=true
ACTIVITY_LOGGER_SUBJECT_RETURN_TYPE=string

# -------------------------------
# Application Timezone & Locale
# -------------------------------
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -------------------------------
# Sanctum & API Configuration
# -------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DOMAIN=localhost

# -------------------------------
# Miscellaneous
# -------------------------------
VITE_APP_NAME="${APP_NAME}"
